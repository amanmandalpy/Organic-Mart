# Select local/test/production settings explicitly outside manage.py.
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-this-for-local-development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_HSTS_SECONDS=0
API_DOCS_ENABLED=True

# PostgreSQL.
#
# Local beginner path:
# - If you run `python manage.py runserver` directly and leave DATABASE_URL and
#   CACHE_URL unset, config.settings.local uses SQLite + local-memory cache.
#
# Production path:
# - Set a real PostgreSQL URL before deploying.
POSTGRES_DB=organicmart
POSTGRES_USER=organicmart
POSTGRES_PASSWORD=organicmart
# DATABASE_URL=postgresql://organicmart:strong-password@127.0.0.1:5432/organicmart
DATABASE_CONN_MAX_AGE=60
# Optional: leave CACHE_URL unset for Django local-memory cache on a small VPS.
# CACHE_URL=locmemcache://organicmart-production

# Comma-separated browser origins; keep empty for same-origin web use.
CORS_ALLOWED_ORIGINS=
API_ANON_THROTTLE_RATE=60/min
API_USER_THROTTLE_RATE=300/min

# Local email prints to the terminal. Production will use a provider URL.
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=OrganicMart <noreply@example.com>
SERVER_EMAIL=errors@example.com

# Added by later modules; never commit real values.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL_ALIAS=
MEDIA_STORAGE_BUCKET=
MEDIA_STORAGE_REGION=
SENTRY_DSN=

LOG_LEVEL=INFO
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60
